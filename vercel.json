{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    { "src": "web/package.json", "use": "@vercel/next" },
    { "src": "api/index.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } }
  ],
  "routes": [{ "src": "/api/(.*)", "dest": "/api/index.py" }]
}
